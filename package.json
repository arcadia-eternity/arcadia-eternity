{
  "name": "arcadia-eternity",
  "private": true,
  "version": "3.2.8",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/arcadia-eternity/arcadia-eternity.git"
  },
  "scripts": {
    "prepare": "husky",
    "build": "run-s lint build:package typecheck build:cli",
    "build:prod": "run-s build:package build:cli",
    "watch": "run-p watch:package watch:cli",
    "clear": "run-p clear:package clear:cli",
    "build:package": "pnpm --filter \"./packages/**\" --filter=!@arcadia-eternity/web-ui run build",
    "watch:package": "pnpm --filter \"./packages/**\" --filter=!@arcadia-eternity/web-ui --parallel run watch",
    "clear:package": "pnpm --filter \"./packages/**\" --filter=!@arcadia-eternity/web-ui run clear",
    "build:cli": "rolldown -c",
    "watch:cli": "rolldown -c --watch",
    "clear:cli": "rm -rf dist",
    "generate": "pnpm --filter @arcadia-eternity/schema run generate",
    "cli": "tsx ./bin/cli.ts",
    "web:dev": "pnpm --filter @arcadia-eternity/web-ui run dev",
    "lint": "pnpm exec eslint .",
    "format": "pnpm exec prettier --write .",
    "format:check": "pnpm exec prettier --check .",
    "typecheck": "pnpm exec tsgo --noEmit",
    "test": "run-s test:types test:run",
    "test:types": "pnpm exec tsgo --noEmit",
    "test:run": "pnpm --filter \"./packages/**\" --if-present run test:run",
    "test:watch": "pnpm --filter \"./packages/**\" --if-present run test"
  },
  "dependencies": {
    "@arcadia-eternity/battle": "workspace:^",
    "@arcadia-eternity/cli-validator": "workspace:^",
    "@arcadia-eternity/client": "workspace:^",
    "@arcadia-eternity/console": "workspace:^",
    "@arcadia-eternity/const": "workspace:^",
    "@arcadia-eternity/data-repository": "workspace:^",
    "@arcadia-eternity/database": "workspace:^",
    "@arcadia-eternity/interface": "workspace:^",
    "@arcadia-eternity/p2p-transport": "workspace:^",
    "@arcadia-eternity/pack-loader": "workspace:^",
    "@arcadia-eternity/rules": "workspace:^",
    "@arcadia-eternity/schema": "workspace:^",
    "@arcadia-eternity/server": "workspace:^",
    "@tsparticles/vue3": "^3.0.1",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "i18next": "catalog:",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "ts-morph": "^28.0.0",
    "tsparticles": "^3.9.1",
    "vue-eslint-parser": "^10.4.0",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "rolldown": "^1.0.0-rc.18",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript/native-preview": "catalog:",
    "bun-types": "^1.3.13",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.3",
    "quicktype": "^23.2.6",
    "quicktype-core": "^23.2.6",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.59.2",
    "typescript-json-schema": "^0.67.1",
    "undici-types": "^8.2.0",
    "vitest": "catalog:"
  },
  "bin": "./dist/cli.js",
  "workspaces": [
    "packages/*",
    "packs/*"
  ],
  "pnpm": {
    "overrides": {
      "yauzl": "3.2.1",
      "postcss": ">=8.5.10",
      "@xmldom/xmldom": ">=0.8.13",
      "dompurify": ">=3.4.0",
      "fast-xml-parser": ">=5.7.0",
      "protobufjs": ">=7.5.5",
      "picomatch": ">=4.0.4",
      "lodash": ">=4.18.0",
      "lodash-es": ">=4.18.0",
      "follow-redirects": ">=1.16.0",
      "brace-expansion": ">=5.0.5",
      "flatted": ">=3.4.2",
      "socket.io-parser": ">=4.2.6",
      "defu": ">=6.1.5",
      "i18next-http-backend": ">=3.0.5",
      "i18next-fs-backend": ">=2.6.4"
    }
  }
}
