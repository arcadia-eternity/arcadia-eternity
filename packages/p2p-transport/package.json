{
  "name": "@arcadia-eternity/p2p-transport",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "run-p build:code build:types",
    "clear": "rm -rf dist",
    "build:code": "rollup -c",
    "watch:code": "rollup -c --watch",
    "watch:types": "pnpm exec tsgo -p tsconfig.build.json --emitDeclarationOnly --watch --preserveWatchOutput",
    "watch": "run-p watch:code watch:types",
    "build:types": "pnpm exec tsgo -p tsconfig.build.json --emitDeclarationOnly",
    "test:run": "vitest run test/*.test.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@arcadia-eternity/battle": "workspace:^",
    "peerjs": "^1.5.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
