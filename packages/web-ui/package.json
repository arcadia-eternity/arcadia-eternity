{
  "name": "@arcadia-eternity/web-ui",
  "version": "3.2.5",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/arcadia-eternity/arcadia-eternity.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-s build:deps \"build-only {@}\" --",
    "build:deps": "pnpm --filter @arcadia-eternity/pack-loader run build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:online": "pnpm run test:e2e:online:relay",
    "test:e2e:online:relay": "cross-env PLAYWRIGHT_ONLINE=1 PLAYWRIGHT_P2P_TRANSPORT=relay playwright test e2e/private-room-online.spec.ts",
    "test:e2e:online:webrtc": "cross-env PLAYWRIGHT_ONLINE=1 PLAYWRIGHT_P2P_TRANSPORT=webrtc playwright test e2e/private-room-online.spec.ts",
    "test:e2e:online:ranked": "cross-env PLAYWRIGHT_ONLINE=1 playwright test e2e/ranked-online.spec.ts",
    "test:e2e:online:ranked:external": "cross-env PLAYWRIGHT_ONLINE=1 PLAYWRIGHT_BASE_URL=http://127.0.0.1:4176 playwright test e2e/ranked-online.spec.ts --config playwright.external.config.ts",
    "test:e2e:online:relay:external": "cross-env PLAYWRIGHT_ONLINE=1 PLAYWRIGHT_BASE_URL=http://127.0.0.1:4176 PLAYWRIGHT_P2P_TRANSPORT=relay playwright test e2e/private-room-online.spec.ts --config playwright.external.config.ts",
    "test:e2e:online:webrtc:external": "cross-env PLAYWRIGHT_ONLINE=1 PLAYWRIGHT_BASE_URL=http://127.0.0.1:4176 PLAYWRIGHT_P2P_TRANSPORT=webrtc playwright test e2e/private-room-online.spec.ts --config playwright.external.config.ts",
    "test:e2e:headed": "playwright test --headed",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore --config .oxlintrc.json || true",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:eslint",
    "format": "prettier --write src/",
    "dev:desktop": "run-p dev:desktop:web electron:dev",
    "dev:desktop:web": "vite --host localhost --port 5173 --strictPort",
    "electron:dev": "wait-on http://localhost:5173 && cross-env ARCADIA_ELECTRON_DEV_SERVER_URL=http://localhost:5173 electron ./electron/main.mjs --remote-debugging-port=9222",
    "build:desktop": "run-s build electron:pack",
    "electron:pack": "electron-builder",
    "electron:pack:publish": "electron-builder --publish always"
  },
  "dependencies": {
    "@arcadia-eternity/client": "workspace:^",
    "@arcadia-eternity/const": "workspace:^",
    "@arcadia-eternity/data-repository": "workspace:^",
    "@arcadia-eternity/database": "workspace:^",
    "@arcadia-eternity/interface": "workspace:^",
    "@arcadia-eternity/p2p-transport": "workspace:^",
    "@arcadia-eternity/pack-loader": "workspace:^",
    "@arcadia-eternity/protocol": "workspace:^",
    "@arcadia-eternity/rules": "workspace:^",
    "@arcadia-eternity/schema": "workspace:^",
    "@comfyorg/litegraph": "^0.17.2",
    "@element-plus/icons-vue": "^2.3.2",
    "@faker-js/faker": "^10.3.0",
    "@heroicons/vue": "^2.2.0",
    "@ruffle-rs/ruffle": "0.2.0-nightly.2026.3.15",
    "@sinclair/typebox": "catalog:",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/vue-table": "^8.21.3",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/slim": "^3.9.1",
    "@tsparticles/vue3": "^3.0.1",
    "@types/ua-parser-js": "^0.7.39",
    "@vueuse/core": "^14.2.1",
    "@vueuse/sound": "^2.1.3",
    "axios": "^1.15.0",
    "electron-updater": "^6.8.3",
    "element-plus": "^2.13.5",
    "gsap": "^3.14.2",
    "howler": "^2.2.4",
    "i18next": "catalog:",
    "i18next-chained-backend": "^5.0.2",
    "i18next-http-backend": "^3.0.2",
    "i18next-vue": "^5.4.0",
    "jsondiffpatch": "catalog:",
    "markdown-it": "^14.1.1",
    "mitt": "^3.0.1",
    "monaco-editor": "^0.55.1",
    "nanoid": "catalog:",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "rxjs": "catalog:",
    "seer2-pet-animator": "^0.0.37",
    "sortablejs": "^1.15.7",
    "sortablejs-vue3": "^1.3.0",
    "tailwindcss": "^4.2.1",
    "tsparticles": "^3.9.1",
    "ua-parser-js": "^2.0.9",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@rollup/plugin-yaml": "^4.1.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/howler": "^2.2.12",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "eslint-plugin-oxlint": "^1.55.0",
    "eslint-plugin-vue": "^10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.55.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tailwind-scrollbar": "^4.0.2",
    "typescript": "catalog:",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.5",
    "vite-plugin-static-copy": "^3.3.0",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vitest": "catalog:",
    "vue-tsc": "^3.2.5",
    "wait-on": "^9.0.4"
  },
  "main": "electron/main.mjs",
  "build": {
    "appId": "com.arcadia.eternity",
    "productName": "Arcadia Eternity",
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "arcadia-eternity",
        "repo": "arcadia-eternity"
      }
    ],
    "mac": {
      "identity": null,
      "target": [
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
