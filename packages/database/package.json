{
  "name": "@arcadia-eternity/database",
  "version": "1.0.0",
  "description": "Database layer for Arcadia Eternity battle reports",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/arcadia-eternity/arcadia-eternity.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "run-p build:code build:types",
    "clear": "rm -rf dist",
    "build:code": "rolldown -c",
    "watch:code": "rolldown -c --watch",
    "watch:types": "pnpm exec tsgo --emitDeclarationOnly --watch --preserveWatchOutput",
    "watch": "run-p watch:code watch:types",
    "build:types": "pnpm exec tsgo --emitDeclarationOnly"
  },
  "keywords": [
    "database",
    "supabase",
    "battle-reports"
  ],
  "author": "yuuinih",
  "license": "MIT",
  "dependencies": {
    "@arcadia-eternity/const": "workspace:^",
    "@supabase/supabase-js": "^2.99.1",
    "inversify": "^8.1.0",
    "nanoid": "catalog:",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tslib": "^2.8.1",
    "typescript": "catalog:"
  }
}
