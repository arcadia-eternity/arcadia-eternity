{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist/src",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "composite": false,
    "incremental": false,
    "tsBuildInfoFile": "./node_modules/.tmp/schema-build.tsbuildinfo"
  },
  "include": ["./src/**/*"],
  "exclude": ["./node_modules", "./dist"]
}
