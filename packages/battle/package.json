{
  "name": "@arcadia-eternity/battle",
  "version": "1.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/arcadia-eternity/arcadia-eternity.git"
  },
  "description": "",
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/types/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "run-s clear build:code build:types",
    "clear": "rm -rf dist",
    "build:code": "rolldown -c",
    "watch:code": "rolldown -c --watch",
    "watch:types": "pnpm exec tsgo --emitDeclarationOnly --watch --preserveWatchOutput",
    "watch": "run-p watch:code watch:types",
    "build:types": "pnpm exec tsgo --emitDeclarationOnly",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [],
  "author": "yuuinih",
  "license": "MIT",
  "dependencies": {
    "@arcadia-eternity/const": "workspace:*",
    "@arcadia-eternity/engine": "workspace:*",
    "@arcadia-eternity/plugin-damage": "workspace:*",
    "@arcadia-eternity/plugin-element": "workspace:*",
    "@arcadia-eternity/plugin-transformation": "workspace:*",
    "@sinclair/typebox": "catalog:",
    "jsondiffpatch": "catalog:",
    "mitt": "^3.0.1",
    "nanoid": "catalog:",
    "prando": "^6.0.1",
    "rxjs": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:"
  }
}
