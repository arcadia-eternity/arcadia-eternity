{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "lib": ["ESNext"],
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "outDir": "./dist/types/",
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./index.ts", "./node.ts", "./src/index.ts", "./src/logger.ts", "./src/v2/**/*"],
  "exclude": ["./node_modules", "./dist", "./src/**/__tests__"]
}
