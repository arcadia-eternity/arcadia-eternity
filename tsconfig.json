{
  "compilerOptions": {
    "composite": true,
    "lib": ["ESNext"],
    "module": "ESNext",
    "target": "ESNext",
    "paths": {
      "*": ["./*"],
      "@data/": ["./packages/data-pack-base/data"]
    },
    "outDir": "./dist/",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["./bin/**/*"],
  "exclude": ["./node_modules", "./dist"]
}
